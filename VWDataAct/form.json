{
    "elements": [
        {
            "type": "Select",
            "name": "SourceMode",
            "caption": "Datenquelle",
            "options": [
                { "caption": "Ordner / Lokale ZIP-Datei", "value": "file" },
                { "caption": "Automatischer Download vom Portal (drivesomethinggreater.com)", "value": "api" }
            ]
        },
        {
            "type": "ValidationTextBox",
            "name": "FilePath",
            "caption": "ZIP-Dateipfad oder Ordnerpfad (für Lokalen Modus)"
        },
        {
            "type": "ExpansionPanel",
            "caption": "VW EU Data Act Portal Zugangsdaten (für Portal Download)",
            "items": [
                {
                    "type": "ValidationTextBox",
                    "name": "PortalUsername",
                    "caption": "E-Mail (VW ID / myAudi / Cupra / SEAT ID)"
                },
                {
                    "type": "PasswordTextBox",
                    "name": "PortalPassword",
                    "caption": "Passwort"
                },
                {
                    "type": "ValidationTextBox",
                    "name": "PortalVIN",
                    "caption": "Fahrzeug-ID (VIN / FIN)"
                }
            ]
        },
        {
            "type": "NumberSpinner",
            "name": "PollInterval",
            "caption": "Import Intervall (Minuten, 0 = Manuell)",
            "minimum": 0,
            "maximum": 1440,
            "suffix": " min"
        },
        {
            "type": "ExpansionPanel",
            "caption": "Datenbereich Feature-Toggles",
            "items": [
                {
                    "type": "CheckBox",
                    "name": "EnableHVBattery",
                    "caption": "Hochvolt-Akku & PV-Laden aktivieren"
                },
                {
                    "type": "CheckBox",
                    "name": "Enable12VBordnetz",
                    "caption": "12V-Bordnetz & Akku-Diagnose aktivieren"
                },
                {
                    "type": "CheckBox",
                    "name": "EnableSecurity",
                    "caption": "Sicherheit & Fahrzeugstatus aktivieren"
                },
                {
                    "type": "CheckBox",
                    "name": "EnableTyrePressure",
                    "caption": "Reifendruck & Sensorik aktivieren"
                },
                {
                    "type": "CheckBox",
                    "name": "EnableClimatisation",
                    "caption": "Klima, Komfort & Verbraucher aktivieren"
                },
                {
                    "type": "CheckBox",
                    "name": "EnableService",
                    "caption": "Laufleistung, Wartung & Systemzustand aktivieren"
                }
            ]
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "Vom Portal Herunterladen & Importieren",
            "onClick": "VWDA_DownloadAndImport($id);"
        },
        {
            "type": "Button",
            "caption": "Lokale Daten Importieren & Aktualisieren",
            "onClick": "VWDA_UpdateData($id);"
        },
        {
            "type": "Button",
            "caption": "Visualisierung Neu Rendern",
            "onClick": "VWDA_RenderTileVisualization($id);"
        }
    ],
    "status": [
        {
            "code": 102,
            "icon": "active",
            "caption": "VW EU Data Act Telemetry Modul ist aktiv."
        },
        {
            "code": 201,
            "icon": "error",
            "caption": "Dateipfad oder Portal-Zugangsdaten nicht angegeben."
        },
        {
            "code": 202,
            "icon": "error",
            "caption": "Fehler beim Lesen, Entpacken oder Portal-Download des Telemetrie-ZIPs."
        },
        {
            "code": 203,
            "icon": "error",
            "caption": "Portal-Anmeldung (VW ID Login) fehlgeschlagen."
        }
    ]
}
